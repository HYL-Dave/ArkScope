# =============================================================================
# MindfulRL-Intraday .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials and Secrets (CRITICAL - never commit!)
# -----------------------------------------------------------------------------
.env
*.env
.env.*
!.env.template
config/.env
api_keys*.txt
*_credentials.json
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# IDE and Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Data Files (too large for git)
# -----------------------------------------------------------------------------
*.parquet
*.csv
!config/*.csv
*.db
*.duckdb
*.sqlite
*.sqlite3
/data/
data_lake/
NewsExtraction/fnspid_*.csv
NewsExtraction/fnspid_*.parquet
NewsExtraction/*.db
NewsExtraction/checkpoints/
NewsExtraction/checkpoints_readcsvs/
NewsExtraction/data_quality_report.json
NewsExtraction/data_summary.json

# -----------------------------------------------------------------------------
# Output and Results (generated by scripts)
# -----------------------------------------------------------------------------
comparison_results/
data_sources/comparison_data/
out/
results/
news_source_comparison.json
data_sources/ibkr_api_test_results.json

# -----------------------------------------------------------------------------
# Screenshots and Images
# -----------------------------------------------------------------------------
ibkr_subscribe*.png

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------------------------------------
# Caches
# -----------------------------------------------------------------------------
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.cache

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak

# -----------------------------------------------------------------------------
# Test and Coverage
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Build and Distribution
# -----------------------------------------------------------------------------
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# Serena MCP
# -----------------------------------------------------------------------------
.serena/

# -----------------------------------------------------------------------------
# Local Documentation (commit locally, don't push to remote)
# These files contain project-specific instructions for Claude Code
# -----------------------------------------------------------------------------
CLAUDE.md
*/CLAUDE.md
**/CLAUDE.md
ANALYSIS_FINDINGS.md

# -----------------------------------------------------------------------------
# Local-only files (never track)
# -----------------------------------------------------------------------------
*.local.md
*.local.txt
*.local.json
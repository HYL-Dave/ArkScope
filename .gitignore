# -----------------------------------------------------------------------------
# Credentials and Secrets (CRITICAL - never commit!)
# -----------------------------------------------------------------------------
.env
*.env
.env.*
!.env.template
config/.env
config/user_profile.local.yaml
config/sa_session.json
config/scoring_keys.txt
scoring_keys*.txt
.mcp.json
api_keys*.txt
*_credentials.json
secrets/

# Codex local state
.codex
.codex/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------

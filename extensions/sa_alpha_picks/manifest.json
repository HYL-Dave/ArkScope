{
  "manifest_version": 3,
  "name": "SA Alpha Picks Exporter",
  "version": "1.0.0",
  "description": "Export Seeking Alpha Alpha Picks portfolio data for MindfulRL agent",
  "permissions": [
    "scripting",
    "nativeMessaging",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://seekingalpha.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SA Alpha Picks"
  },
  "icons": {}
}

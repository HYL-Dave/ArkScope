# =============================================================================
# MindfulRL-Intraday API Credentials Template
# =============================================================================
#
# IMPORTANT:
# 1. Copy this file to .env (which is gitignored)
# 2. Fill in your API keys
# 3. NEVER commit .env to git
#
# Command: cp config/.env.template .env
# =============================================================================

# -----------------------------------------------------------------------------
# Primary Data Sources (Choose at least one)
# -----------------------------------------------------------------------------

# Tiingo API (Recommended for EOD stock prices)
# Sign up: https://www.tiingo.com/
# Free tier: 500 symbols/month, 50 symbols/hour, 30+ years EOD data
# ⚠️ NEWS API REQUIRES PAID TIER - Free returns 403 Forbidden
TIINGO_API_KEY=your_tiingo_api_key_here

# Finnhub API
# Sign up: https://finnhub.io/
# Free tier: 60 calls/minute, real-time quotes
# ⚠️ NEWS HISTORY: ~7 days ONLY (not 1 year as documented!)
#    Historical queries (2024/01, 2023/01, etc.) return 0 results
FINNHUB_API_KEY=your_finnhub_api_key_here

# Financial Datasets API
# Sign up: https://www.financialdatasets.ai/
# No free tier - minimum $20 credits or $200/month subscription
FINANCIAL_DATASETS_API_KEY=your_financial_datasets_api_key_here

# -----------------------------------------------------------------------------
# LLM Services (For Sentiment/Risk Scoring)
# -----------------------------------------------------------------------------

# OpenAI API (Primary)
# Sign up: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Multiple API keys for rotation (comma-separated)
# Format: keys separated by comma, NO quotes around individual keys
#   Correct: OPENAI_API_KEYS=sk-xxx,sk-yyy,sk-zzz
#   Correct: OPENAI_API_KEYS="sk-xxx,sk-yyy,sk-zzz"
#   WRONG:   OPENAI_API_KEYS="sk-xxx","sk-yyy"  <- python-dotenv cannot parse!
# OPENAI_API_KEYS=key1,key2,key3

# Anthropic Claude API
# Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API
# Sign up: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# xAI Grok API
# Sign up: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# DeepSeek API
# Sign up: https://www.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# -----------------------------------------------------------------------------
# Web Search Services (Phase 10)
# -----------------------------------------------------------------------------

# Tavily API (Web search + URL content extraction)
# Sign up: https://tavily.com/
# Free tier: 1000 credits/month (basic search = 1 credit, advanced = 2 credits)
TAVILY_API_KEY=your_tavily_api_key_here

# -----------------------------------------------------------------------------
# Optional Data Sources
# -----------------------------------------------------------------------------

# Alpha Vantage
# Sign up: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/DAY (very limited!), 5 calls/minute
# Features: News with AI sentiment, 20+ years prices, technical indicators
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Polygon.io
# Sign up: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# EODHD (EOD Historical Data)
# Sign up: https://eodhd.com/
# Free tier: 20 calls/day, 1 year history, Demo tickers unlimited
# Paid: $19.99+/month, 100k calls/day, 1972+ EOD history
# Features: 150k+ tickers, 60+ exchanges, news + sentiment, fundamentals
EODHD_API_KEY=your_eodhd_api_key_here

# Financial Modeling Prep (FMP)
# Sign up: https://financialmodelingprep.com/
# Free tier: 250 calls/day
# Features: Senate/House trading disclosures, fundamentals, news, SEC filings
FMP_API_KEY=your_fmp_api_key_here

# Reddit (for social sentiment)
# Create app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Interactive Brokers (IBKR) - requires account
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# -----------------------------------------------------------------------------
# Discord Bot (Monitor/Gateway, Phase E)
# -----------------------------------------------------------------------------

# Discord Bot Token
# Create at: https://discord.com/developers/applications
# Required permissions: Send Messages, Embed Links, Read Message History
# OAuth2 scopes: bot, applications.commands
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Channel IDs (right-click channel → Copy Channel ID, requires Developer Mode)
DISCORD_CHANNEL_ID=your_main_channel_id_here
DISCORD_ALERT_CHANNEL_ID=your_alert_channel_id_here
DISCORD_AGENT_CHANNEL_ID=your_agent_channel_id_here
DISCORD_REPORT_CHANNEL_ID=your_report_channel_id_here

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL connection string (primary)
# Docker local:  postgresql://postgres:mindfulrl_dev_2026@localhost:15432/mindfulrl
# Remote server: postgresql://postgres:password@hostname:15432/mindfulrl
DATABASE_URL=postgresql://postgres:mindfulrl_dev_2026@localhost:15432/mindfulrl

# SSL mode (optional — auto-detected if not set)
#   localhost/LAN IP → disable, remote → require
# DB_SSLMODE=disable

# Legacy: Supabase Cloud (used as fallback if DATABASE_URL is not set)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@host:6543/postgres

# -----------------------------------------------------------------------------
# Cost Control Settings
# -----------------------------------------------------------------------------

# Daily cost limits (in USD)
DAILY_COST_LIMIT_USD=50.0
MONTHLY_COST_LIMIT_USD=500.0

# LLM model preferences (cost optimization)
# Options: gpt-5.2, gpt-5.2-codex
DEFAULT_LLM_MODEL=gpt-5.2

# -----------------------------------------------------------------------------
# Logging and Debug
# -----------------------------------------------------------------------------

LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG  # Uncomment for verbose logging

# Enable API response logging (careful with costs!)
# LOG_API_RESPONSES=true

